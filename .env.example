# Server
HOST=0.0.0.0
PORT=8080

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password

# Magic link base URL
# - Quick Tunnel (Option A, free): each cloudflared session issues a temporary *.trycloudflare.com domain.
#   Update this value every time you restart the tunnel.
#   e.g. MAGIC_LINK_BASE_URL=https://harris-existed-criteria-peterson.trycloudflare.com
# - Named Tunnel (Option B, paid): set once to your fixed custom domain.
#   e.g. MAGIC_LINK_BASE_URL=https://your-domain.com
MAGIC_LINK_BASE_URL=https://your-domain.com

# Security
# Generate SESSION_SECRET with: uv run python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change_me_to_random_string
TOKEN_EXPIRE_MINUTES=15
SESSION_EXPIRE_DAYS=7
ADMIN_EMAIL=your@gmail.com
